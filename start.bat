@echo off
title ZATMENIE LAUNCHER

echo ==========================================
echo    ЗАПУСК СИСТЕМЫ ZATMENIE...
echo ==========================================

:: 1. Запускаем БОТА в отдельном окне
:: Параметр /k не дает окну закрыться, если вылетит ошибка (удобно для отладки)
echo [1/2] Запускаю bot.py...
start "TELEGRAM BOT (LOGS)" cmd /k "python bot.py"

:: Даем боту пару секунд на старт и создание таблиц БД
timeout /t 2 /nobreak >nul

:: 2. Запускаем АДМИНКУ (God Mode) в отдельном окне
echo [2/2] Запускаю god_mode.py...
start "ADMIN PANEL (GOD MODE)" cmd /k "python god_mode.py"

echo.
echo ==========================================
echo    УСПЕШНО!
echo    Открыто два окна: Бот и Админка.
echo    Не закрывайте их, пока работаете.
echo ==========================================
pause